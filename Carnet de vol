<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Carnet de Vol</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root{--bg:#0a0e17;--panel:#111827;--panel2:#1a2236;--accent:#00d4ff;--accent2:#ff6b35;--green:#00ff88;--plane:#ff9f43;--sim:#b06aff;--text:#e2e8f0;--muted:#64748b;--border:rgba(0,212,255,0.2);--night:#7c6fcd;--day:#f6c90e;--font-mono:'Share Tech Mono',monospace;--font:'Barlow',sans-serif;}
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;display:flex;flex-direction:column;align-items:center;}
  .app{width:100%;max-width:480px;min-height:100vh;display:flex;flex-direction:column;}
 
  /* ── SETUP SCREEN ── */
  .setup-screen{flex:1;display:flex;flex-direction:column;justify-content:center;padding:30px 24px;}
  .setup-logo{text-align:center;margin-bottom:24px;}
  .setup-logo .icon{font-size:48px;margin-bottom:8px;}
  .setup-logo h1{font-size:22px;font-weight:700;letter-spacing:0.05em;}
  .setup-logo p{font-family:var(--font-mono);font-size:11px;color:var(--accent);margin-top:4px;}
  .setup-section{margin-bottom:20px;}
  .setup-section-title{font-family:var(--font-mono);font-size:10px;color:var(--accent);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
  .setup-section-title::after{content:'';flex:1;height:1px;background:var(--border);}
  .setup-field{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
  .setup-field label{font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}
  .setup-field input{background:var(--panel2);border:1px solid var(--border);border-radius:6px;padding:11px 14px;color:var(--text);font-family:var(--font-mono);font-size:14px;outline:none;transition:border-color 0.2s;width:100%;}
  .setup-field input:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,212,255,0.1);}
  .setup-note{font-family:var(--font-mono);font-size:10px;color:var(--muted);padding:10px 14px;background:rgba(0,212,255,0.05);border:1px solid var(--border);border-radius:6px;line-height:1.6;margin-bottom:16px;}
  .setup-note a{color:var(--accent);}
  .btn-setup{width:100%;padding:16px;background:linear-gradient(135deg,var(--accent) 0%,#0066ff 100%);border:none;border-radius:10px;color:#000;font-family:var(--font);font-size:15px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;box-shadow:0 4px 20px rgba(0,212,255,0.3);}
  .btn-setup:active{transform:scale(0.98);}
 
  /* ── MAIN APP ── */
  header{padding:18px 20px 14px;border-bottom:1px solid var(--border);background:linear-gradient(180deg,rgba(0,212,255,0.05) 0%,transparent 100%);position:relative;}
  header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
  .header-top{display:flex;align-items:center;gap:12px;}
  .logo{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),#0066ff);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;}
  .app-name{font-size:18px;font-weight:700;letter-spacing:0.05em;}
  .app-sub{font-family:var(--font-mono);font-size:11px;color:var(--accent);letter-spacing:0.1em;}
  .pilot-badge{margin-left:auto;font-family:var(--font-mono);font-size:10px;color:var(--muted);text-align:right;line-height:1.5;}
  .pilot-badge span{display:block;color:var(--green);font-size:11px;}
  .status-bar{display:flex;gap:16px;padding:10px 20px;background:var(--panel);border-bottom:1px solid var(--border);}
  .stat{display:flex;flex-direction:column;gap:2px;}
  .stat-label{font-family:var(--font-mono);font-size:9px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}
  .stat-value{font-family:var(--font-mono);font-size:15px;color:var(--accent);}
  .stat-value.orange{color:var(--accent2);}
  .stat-value.green{color:var(--green);}
  .tabs{display:flex;border-bottom:1px solid var(--border);background:var(--panel);}
  .tab{flex:1;padding:11px 4px;text-align:center;font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;text-transform:uppercase;}
  .tab.active{color:var(--accent);border-bottom-color:var(--accent);background:rgba(0,212,255,0.05);}
  .content{flex:1;padding:16px 20px;overflow-y:auto;}
  .section-title{font-family:var(--font-mono);font-size:10px;color:var(--accent);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
  .section-title::after{content:'';flex:1;height:1px;background:var(--border);}
  .type-toggle{display:flex;gap:8px;margin-bottom:16px;}
  .type-btn{flex:1;padding:10px 6px;border:1px solid var(--border);border-radius:8px;background:var(--panel2);color:var(--muted);font-family:var(--font);font-size:12px;font-weight:600;cursor:pointer;text-align:center;transition:all 0.2s;}
  .type-btn.active-heli{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,0.08);}
  .type-btn.active-plane{border-color:var(--plane);color:var(--plane);background:rgba(255,159,67,0.08);}
  .type-btn.active-sim{border-color:var(--sim);color:var(--sim);background:rgba(176,106,255,0.08);}
  .type-icon{display:block;font-size:20px;margin-bottom:3px;}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
  .form-grid.full{grid-template-columns:1fr;}
  .field{display:flex;flex-direction:column;gap:5px;}
  .field label{font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}
  .field input,.field select{background:var(--panel2);border:1px solid var(--border);border-radius:6px;padding:10px 12px;color:var(--text);font-family:var(--font-mono);font-size:14px;outline:none;transition:border-color 0.2s;width:100%;-webkit-appearance:none;}
  .field input:focus,.field select:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,212,255,0.1);}
  .field select option{background:var(--panel);}
  .clock-group{display:flex;flex-direction:column;gap:5px;}
  .clock-label{font-family:var(--font-mono);font-size:10px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}
  .clock-row{display:flex;gap:6px;align-items:stretch;}
  .clock-stamp{flex:1;padding:0 12px;background:var(--panel2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:var(--font-mono);font-size:18px;cursor:pointer;text-align:center;height:44px;display:flex;align-items:center;justify-content:center;user-select:none;position:relative;overflow:hidden;transition:all 0.15s;}
  .clock-stamp.stamped{border-color:var(--green);color:var(--green);background:rgba(0,255,136,0.07);}
  .clock-stamp.stamped-plane{border-color:var(--plane);color:var(--plane);background:rgba(255,159,67,0.07);}
  .clock-stamp.stamped-sim{border-color:var(--sim);color:var(--sim);background:rgba(176,106,255,0.07);}
  .clock-stamp:active{transform:scale(0.97);}
  .ripple{position:absolute;border-radius:50%;background:rgba(0,255,136,0.35);transform:scale(0);animation:ripple-anim 0.4s linear;pointer-events:none;}
  @keyframes ripple-anim{to{transform:scale(4);opacity:0;}}
  .clock-edit{width:40px;height:44px;background:var(--panel2);border:1px solid var(--border);border-radius:6px;color:var(--muted);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.15s;}
  .clock-edit:hover{border-color:var(--accent);color:var(--accent);}
  .clock-editor{display:none;margin-top:6px;}
  .clock-editor.open{display:flex;gap:6px;align-items:center;}
  .clock-editor input[type="time"]{flex:1;background:var(--panel2);border:1px solid var(--accent);border-radius:6px;padding:8px 12px;color:var(--text);font-family:var(--font-mono);font-size:15px;outline:none;-webkit-appearance:none;}
  .clock-editor-ok{padding:8px 14px;background:var(--accent);border:none;border-radius:6px;color:#000;font-family:var(--font-mono);font-size:13px;font-weight:700;cursor:pointer;}
  .clock-editor-cancel{padding:8px 10px;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--muted);font-family:var(--font-mono);font-size:13px;cursor:pointer;}
  .duration-block{background:var(--panel2);border:1px solid var(--border);border-radius:8px;padding:12px 14px;margin-bottom:14px;}
  .duration-main{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
  .duration-label{font-family:var(--font-mono);font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;}
  .duration-value{font-family:var(--font-mono);font-size:22px;color:var(--green);}
  .dn-bar-wrap{margin-bottom:8px;}
  .dn-bar{height:8px;border-radius:4px;overflow:hidden;background:var(--panel);display:flex;}
  .dn-bar-day{background:var(--day);transition:width 0.4s;}
  .dn-bar-night{background:var(--night);transition:width 0.4s;}
  .dn-labels{display:flex;justify-content:space-between;margin-top:5px;}
  .dn-label{font-family:var(--font-mono);font-size:11px;display:flex;align-items:center;gap:5px;}
  .dn-dot{width:8px;height:8px;border-radius:50%;display:inline-block;}
  .dn-dot.day{background:var(--day);}
  .dn-dot.night{background:var(--night);}
  .dn-time{font-size:13px;}
  .gps-bar{display:flex;align-items:center;gap:8px;padding:7px 12px;background:var(--panel2);border:1px solid var(--border);border-radius:6px;margin-bottom:14px;font-family:var(--font-mono);font-size:11px;color:var(--muted);}
  .gps-dot{width:8px;height:8px;border-radius:50%;background:var(--muted);flex-shrink:0;}
  .gps-dot.ok{background:var(--green);box-shadow:0 0 6px rgba(0,255,136,0.5);}
  .gps-dot.loading{background:var(--accent);animation:pulse 1s infinite;}
  .gps-dot.error{background:#ff4444;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.3;}}
  .gps-text{flex:1;}
  .gps-refresh{background:none;border:none;color:var(--accent);font-family:var(--font-mono);font-size:11px;cursor:pointer;padding:0;}
  .sun-times{display:flex;gap:8px;margin-bottom:14px;}
  .sun-card{flex:1;background:var(--panel2);border:1px solid var(--border);border-radius:6px;padding:8px 10px;text-align:center;}
  .sun-icon{font-size:14px;margin-bottom:2px;}
  .sun-label{font-family:var(--font-mono);font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;display:block;}
  .sun-time{font-family:var(--font-mono);font-size:14px;color:var(--text);}
  .sun-time.civil{font-size:10px;color:var(--muted);}
  .aircraft-row{display:flex;align-items:flex-end;gap:8px;margin-bottom:14px;}
  .aircraft-row .field{flex:1;}
  .aircraft-type-badge{padding:10px 12px;border:1px solid var(--border);border-radius:6px;background:var(--panel2);font-family:var(--font-mono);font-size:12px;white-space:nowrap;color:var(--muted);min-width:90px;text-align:center;height:40px;display:flex;align-items:center;justify-content:center;}
  .aircraft-type-badge.heli{color:var(--accent);border-color:rgba(0,212,255,0.4);}
  .aircraft-type-badge.plane{color:var(--plane);border-color:rgba(255,159,67,0.4);}
  .aircraft-type-badge.sim{color:var(--sim);border-color:rgba(176,106,255,0.4);}
  .btn-submit{width:100%;padding:15px;background:linear-gradient(135deg,var(--accent) 0%,#0066ff 100%);border:none;border-radius:10px;color:#000;font-family:var(--font);font-size:14px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;margin-top:6px;transition:all 0.2s;}
  .btn-submit:active{transform:scale(0.98);}
  .btn-submit:disabled{background:var(--muted);cursor:not-allowed;}
  .btn-submit.plane-mode{background:linear-gradient(135deg,var(--plane) 0%,#e55039 100%);}
  .btn-submit.sim-mode{background:linear-gradient(135deg,var(--sim) 0%,#6a0dad 100%);}
  .modal-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:200;align-items:center;justify-content:center;padding:20px;}
  .modal-backdrop.show{display:flex;}
  .modal{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:20px;width:100%;max-width:340px;}
  .modal-title{font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:16px;}
  .modal-grid{display:flex;flex-direction:column;gap:12px;margin-bottom:16px;}
  .modal-actions{display:flex;gap:8px;}
  .btn-cancel{flex:1;padding:11px;background:transparent;border:1px solid var(--border);border-radius:8px;color:var(--muted);font-family:var(--font);font-size:13px;cursor:pointer;}
  .btn-save{flex:2;padding:11px;background:var(--accent);border:none;border-radius:8px;color:#000;font-family:var(--font);font-size:13px;font-weight:700;cursor:pointer;}
  .btn-danger{flex:1;padding:11px;background:#ff4444;border:none;border-radius:8px;color:#fff;font-family:var(--font);font-size:13px;font-weight:700;cursor:pointer;}
  .loading-overlay{display:none;position:fixed;inset:0;background:rgba(10,14,23,0.8);backdrop-filter:blur(4px);z-index:150;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
  .loading-overlay.show{display:flex;}
  .loading-ring{width:48px;height:48px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite;}
  .loading-text{font-family:var(--font-mono);font-size:13px;color:var(--accent);letter-spacing:0.1em;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--green);color:#000;padding:12px 24px;border-radius:30px;font-weight:700;font-size:14px;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);z-index:300;white-space:nowrap;}
  .toast.error{background:#ff4444;color:#fff;}
  .toast.show{transform:translateX(-50%) translateY(0);}
  .flight-card{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:10px;position:relative;overflow:hidden;animation:fadeIn 0.3s ease;}
  @keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
  .flight-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent);}
  .flight-card.plane-card::before{background:var(--plane);}
  .flight-card.sim-card::before{background:var(--sim);}
  .flight-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;}
  .flight-date{font-family:var(--font-mono);font-size:11px;color:var(--muted);}
  .flight-duration{font-family:var(--font-mono);font-size:14px;color:var(--green);}
  .flight-route{font-size:15px;font-weight:600;margin-bottom:6px;}
  .flight-arrow{color:var(--accent);margin:0 6px;}
  .flight-meta{display:flex;gap:8px;font-family:var(--font-mono);font-size:11px;color:var(--muted);flex-wrap:wrap;}
  .flight-meta span{color:var(--text);}
  .dn-mini{display:flex;gap:6px;margin-top:6px;}
  .dn-pill{font-size:10px;padding:2px 8px;border-radius:4px;font-family:var(--font-mono);}
  .dn-pill.day{background:rgba(246,201,14,0.15);color:var(--day);}
  .dn-pill.night{background:rgba(124,111,205,0.15);color:var(--night);}
  .type-chip{font-size:10px;padding:2px 7px;border-radius:4px;font-family:var(--font-mono);}
  .type-chip.heli{background:rgba(0,212,255,0.15);color:var(--accent);}
  .type-chip.plane{background:rgba(255,159,67,0.15);color:var(--plane);}
  .type-chip.sim{background:rgba(176,106,255,0.15);color:var(--sim);}
  .btn-delete{margin-top:8px;width:100%;padding:7px;background:transparent;border:1px solid rgba(255,68,68,0.3);border-radius:6px;color:#ff6666;font-family:var(--font-mono);font-size:11px;cursor:pointer;transition:all 0.2s;}
  .btn-delete:hover{background:rgba(255,68,68,0.1);border-color:#ff4444;}
  .empty-state{text-align:center;padding:40px 20px;color:var(--muted);}
  .empty-state .icon{font-size:40px;margin-bottom:10px;}
  .add-aircraft-link{font-family:var(--font-mono);font-size:11px;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:3px;margin-top:4px;display:inline-block;}
  .fleet-card{background:var(--panel);border:1px solid var(--border);border-radius:8px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:10px;}
  .fleet-reg{font-family:var(--font-mono);font-size:14px;font-weight:600;flex:1;}
  .fleet-type{font-family:var(--font-mono);font-size:12px;color:var(--muted);flex:1;}
  .fleet-card .del-btn{flex-shrink:0;width:32px;height:32px;background:rgba(255,68,68,0.08);border:1px solid rgba(255,68,68,0.35);border-radius:6px;color:#ff6666;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .settings-link{font-family:var(--font-mono);font-size:11px;color:var(--muted);cursor:pointer;text-decoration:underline;text-underline-offset:3px;display:inline-block;margin-top:8px;}
  .settings-link:hover{color:var(--accent);}
</style>
</head>
<body>
<div class="app" id="app">
 
  <!-- ── SETUP SCREEN ── -->
  <div id="setup-screen" class="setup-screen" style="display:none;">
    <div class="setup-logo">
      <div class="icon">✈</div>
      <h1>CARNET DE VOL</h1>
      <p>PILOT LOGBOOK — CONFIGURATION</p>
    </div>
 
    <div class="setup-section">
      <div class="setup-section-title">Pilote</div>
      <div class="setup-field">
        <label>Nom complet</label>
        <input type="text" id="cfg-pilot-name" placeholder="Jean Dupont">
      </div>
      <div class="setup-field">
        <label>Aérodrome par défaut (OACI)</label>
        <input type="text" id="cfg-home-base" placeholder="LFPG" autocapitalize="characters" maxlength="4">
      </div>
    </div>
 
    <div class="setup-section">
      <div class="setup-section-title">Google Sheets</div>
      <div class="setup-note">
        Suis le guide d'installation pour créer ton Google Sheet et obtenir ton Spreadsheet ID et ta clé API.<br><br>
        Le Spreadsheet ID se trouve dans l'URL de ton sheet :<br>
        <code style="color:var(--accent);">docs.google.com/spreadsheets/d/<b>TON_ID</b>/edit</code>
      </div>
      <div class="setup-field">
        <label>Spreadsheet ID</label>
        <input type="text" id="cfg-sheet-id" placeholder="1ABC...xyz">
      </div>
      <div class="setup-field">
        <label>Email du compte de service</label>
        <input type="text" id="cfg-client-email" placeholder="mon-app@projet.iam.gserviceaccount.com">
      </div>
      <div class="setup-field">
        <label>Clé privée (depuis le fichier JSON)</label>
        <input type="text" id="cfg-private-key" placeholder="-----BEGIN PRIVATE KEY-----...">
      </div>
    </div>
 
    <button class="btn-setup" onclick="saveConfig()">ENREGISTRER ET DÉMARRER ✓</button>
  </div>
 
  <!-- ── MAIN APP ── -->
  <div id="main-app" style="display:none;">
    <header>
      <div class="header-top">
        <div class="logo">✈</div>
        <div><div class="app-name">CARNET DE VOL</div><div class="app-sub">PILOT LOGBOOK</div></div>
        <div class="pilot-badge">PILOTE<span id="header-pilot-name">—</span></div>
      </div>
    </header>
    <div class="status-bar">
      <div class="stat"><div class="stat-label">Vols (session)</div><div class="stat-value" id="stat-flights">0</div></div>
      <div class="stat"><div class="stat-label">Heures (session)</div><div class="stat-value orange" id="stat-hours">0:00</div></div>
      <div class="stat"><div class="stat-label">Statut</div><div class="stat-value green" id="stat-status">PRÊT</div></div>
    </div>
    <div class="tabs">
      <div class="tab active" onclick="switchTab('form')">+ Nouveau vol</div>
      <div class="tab" onclick="switchTab('history')">Historique</div>
      <div class="tab" onclick="switchTab('fleet')">Flotte</div>
    </div>
 
    <div class="content" id="tab-form">
      <div class="section-title">Type d'aéronef</div>
      <div class="type-toggle">
        <div class="type-btn active-heli" id="btn-heli" onclick="setType('heli')"><span class="type-icon">🚁</span>Hélicoptère</div>
        <div class="type-btn" id="btn-plane" onclick="setType('plane')"><span class="type-icon">✈</span>Avion</div>
        <div class="type-btn" id="btn-sim" onclick="setType('sim')"><span class="type-icon">🖥️</span>Simulateur</div>
      </div>
      <div class="section-title">Aéronef</div>
      <div class="aircraft-row">
