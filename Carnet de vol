<script>
// ── CONFIG (chargée depuis localStorage) ─────────────────────────
var CONFIG = {};
 
function loadConfig() {
  try {
    var s = localStorage.getItem('cvol_config');
    CONFIG = s ? JSON.parse(s) : {};
  } catch(e) { CONFIG = {}; }
}
 
function saveConfigToStorage() {
  try { localStorage.setItem('cvol_config', JSON.stringify(CONFIG)); } catch(e) {}
}
 
function isConfigured() {
  return CONFIG.sheetId && CONFIG.clientEmail && CONFIG.privateKey && CONFIG.pilotName;
}
 
// ── INIT ──────────────────────────────────────────────────────────
window.onload = function() {
  loadConfig();
  if (isConfigured()) {
    startApp();
  } else {
    document.getElementById('setup-screen').style.display = '';
  }
};
 
function saveConfig() {
  var name  = document.getElementById('cfg-pilot-name').value.trim();
  var base  = document.getElementById('cfg-home-base').value.trim().toUpperCase();
  var sid   = document.getElementById('cfg-sheet-id').value.trim();
  var email = document.getElementById('cfg-client-email').value.trim();
  var key   = document.getElementById('cfg-private-key').value.trim();
 
  if (!name || !sid || !email || !key) {
    showToast('⚠ Remplis tous les champs', true); return;
  }
  CONFIG = { pilotName: name, homeBase: base||'ZZZZ', sheetId: sid, clientEmail: email, privateKey: key };
  saveConfigToStorage();
  document.getElementById('setup-screen').style.display = 'none';
  startApp();
}
 
function startApp() {
  document.getElementById('main-app').style.display = '';
  document.getElementById('header-pilot-name').textContent = CONFIG.pilotName || '—';
 
  // Default values
  var today = new Date().toISOString().split('T')[0];
  document.getElementById('f-date').value = today;
  document.getElementById('f-pilots').value = CONFIG.pilotName || '';
  document.getElementById('f-from').value = CONFIG.homeBase || '';
  document.getElementById('f-to').value = CONFIG.homeBase || '';
 
  renderAircraftSelect();
  renderFleet();
  getGPS();
}
 
// ── SETTINGS ─────────────────────────────────────────────────────
function openSettings() {
  document.getElementById('s-pilot-name').value = CONFIG.pilotName || '';
  document.getElementById('s-home-base').value  = CONFIG.homeBase  || '';
  document.getElementById('s-sheet-id').value   = CONFIG.sheetId   || '';
  document.getElementById('modal-settings').classList.add('show');
}
function closeSettings() { document.getElementById('modal-settings').classList.remove('show'); }
function saveSettings() {
  CONFIG.pilotName = document.getElementById('s-pilot-name').value.trim() || CONFIG.pilotName;
  CONFIG.homeBase  = document.getElementById('s-home-base').value.trim().toUpperCase() || CONFIG.homeBase;
  CONFIG.sheetId   = document.getElementById('s-sheet-id').value.trim() || CONFIG.sheetId;
  saveConfigToStorage();
  document.getElementById('header-pilot-name').textContent = CONFIG.pilotName;
  closeSettings();
  showToast('✓ Paramètres sauvegardés');
}
function resetApp() {
  if (!confirm('Réinitialiser complètement l\'application ? (flotte et config effacées)')) return;
  localStorage.clear();
  location.reload();
}
 
// ── FLEET ─────────────────────────────────────────────────────────
function loadFleet() {
  try { var s = localStorage.getItem('cvol_fleet'); return s ? JSON.parse(s) : {}; }
  catch(e) { return {}; }
}
function saveFleet() { try { localStorage.setItem('cvol_fleet', JSON.stringify(fleet)); } catch(e) {} }
var fleet = loadFleet();
 
// ── SUN CALC ─────────────────────────────────────────────────────
function toRad(d){return d*Math.PI/180;}function toDeg(r){return r*180/Math.PI;}
function calcSunTimes(lat,lon,dateStr){
  var JD=new Date(dateStr+'T12:00:00Z').getTime()/86400000+2440587.5;
  var n=Math.floor(JD-2451545.0+0.0008),Jstar=n-lon/360;
  var M=(357.5291+0.98560028*Jstar)%360;
  var C=1.9148*Math.sin(toRad(M))+0.0200*Math.sin(toRad(2*M))+0.0003*Math.sin(toRad(3*M));
  var lam=(M+C+180+102.9372)%360;
  var Jt=2451545.0+Jstar+0.0053*Math.sin(toRad(M))-0.0069*Math.sin(toRad(2*lam));
  var dec=toDeg(Math.asin(Math.sin(toRad(lam))*Math.sin(toRad(23.4397))));
  var cosW=(Math.sin(toRad(-0.833))-Math.sin(toRad(lat))*Math.sin(toRad(dec)))/(Math.cos(toRad(lat))*Math.cos(toRad(dec)));
  if(cosW<-1||cosW>1)return null;
  var W=toDeg(Math.acos(cosW));
  function toUTCMin(J){var d=new Date((J-2440587.5)*86400000);return d.getUTCHours()*60+d.getUTCMinutes();}
  return{rise:toUTCMin(Jt-W/360),set:toUTCMin(Jt+W/360)};
}
function minsToHHMM(m){m=((m%1440)+1440)%1440;return String(Math.floor(m/60)).padStart(2,'0')+':'+String(m%60).padStart(2,'0');}
 
var gpsLat=null,gpsLon=null,sunRiseMin=null,sunSetMin=null,nightStartMin=null,nightEndMin=null;
 
function updateSunDisplay(){
  var date=document.getElementById('f-date').value;
  if(!gpsLat||!date)return;
  var s=calcSunTimes(gpsLat,gpsLon,date);
  if(!s){document.getElementById('sun-rise').textContent='Polaire';return;}
  sunRiseMin=s.rise;sunSetMin=s.set;nightStartMin=sunSetMin+30;nightEndMin=sunRiseMin-30;
  document.getElementById('sun-rise').textContent=minsToHHMM(sunRiseMin);
  document.getElementById('sun-set').textContent=minsToHHMM(sunSetMin);
  document.getElementById('civil-end').textContent='Fin nuit '+minsToHHMM(nightEndMin);
  document.getElementById('civil-start').textContent='Début nuit '+minsToHHMM(nightStartMin);
  document.getElementById('night-start').textContent=minsToHHMM(nightStartMin);
  document.getElementById('night-end').textContent='→ '+minsToHHMM(nightEndMin);
  updateDayNight();
}
 
function calcDayNightMinutes(offMin,onMin,nightStart,nightEnd){
  var total=onMin-offMin;if(total<0)total+=1440;if(total===0)return{day:0,night:0};
  var nightMins=0;
  for(var i=0;i<total;i++){var t=(offMin+i)%1440;if(nightStart>nightEnd?(t>=nightStart||t<nightEnd):(t>=nightStart&&t<nightEnd))nightMins++;}
  return{night:nightMins,day:total-nightMins};
}
 
function updateDayNight(){
  if(!timeOff||!timeOn){document.getElementById('dn-wrap').style.display='none';document.getElementById('dn-no-gps').style.display='';return;}
  if(nightStartMin===null){document.getElementById('dn-no-gps').style.display='';document.getElementById('dn-wrap').style.display='none';return;}
  function toM(t){var p=t.split(':').map(Number);return p[0]*60+p[1];}
  var r=calcDayNightMinutes(toM(timeOff),toM(timeOn),nightStartMin,nightEndMin);
  var total=r.day+r.night;
  document.getElementById('dn-no-gps').style.display='none';
  document.getElementById('dn-wrap').style.display='';
  document.getElementById('dn-bar-day').style.width=(total>0?Math.round(r.day/total*100):50)+'%';
  document.getElementById('dn-bar-night').style.width=(total>0?Math.round(r.night/total*100):50)+'%';
  document.getElementById('dn-day-val').textContent=minsToHHMM(r.day);
  document.getElementById('dn-night-val').textContent=minsToHHMM(r.night);
  window._dayMin=r.day;window._nightMin=r.night;
}
 
function getGPS(){
  var dot=document.getElementById('gps-dot'),txt=document.getElementById('gps-text');
  dot.className='gps-dot loading';txt.textContent='Localisation en cours...';
  if(!navigator.geolocation){dot.className='gps-dot error';txt.textContent='GPS non disponible';return;}
  navigator.geolocation.getCurrentPosition(
    function(pos){gpsLat=pos.coords.latitude;gpsLon=pos.coords.longitude;dot.className='gps-dot ok';txt.textContent=gpsLat.toFixed(3)+'° / '+gpsLon.toFixed(3)+'°';updateSunDisplay();},
    function(){dot.className='gps-dot error';txt.textContent='Accès GPS refusé';},
    {timeout:10000,maximumAge:300000}
  );
}
function onDateChange(){updateSunDisplay();}
 
// ── CLOCK ─────────────────────────────────────────────────────────
var timeOff='',timeOn='';
function stampClass(){return currentType==='plane'?'stamped-plane':currentType==='sim'?'stamped-sim':'stamped';}
function stampTime(which,event){
  var now=new Date();
  var t=now.getUTCHours().toString().padStart(2,'0')+':'+now.getUTCMinutes().toString().padStart(2,'0');
  var btn=document.getElementById('stamp-'+which);
  var r=document.createElement('span');r.className='ripple';
  var sz=Math.max(btn.offsetWidth,btn.offsetHeight);
  r.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+(event.offsetX-sz/2)+'px;top:'+(event.offsetY-sz/2)+'px;';
  btn.appendChild(r);setTimeout(function(){r.remove();},450);
  setTime(which,t);
}
function setTime(which,t){
  if(which==='off'){timeOff=t;var b=document.getElementById('stamp-off');b.textContent=t;b.className='clock-stamp '+stampClass();}
  else{timeOn=t;var b=document.getElementById('stamp-on');b.textContent=t;b.className='clock-stamp '+stampClass();}
  calcDuration();updateDayNight();
}
function toggleEditor(which){
  var ed=document.getElementById('editor-'+which);
  if(ed.classList.contains('open')){closeEditor(which);}
  else{document.getElementById('edit-'+which+'-input').value=which==='off'?timeOff:timeOn;ed.classList.add('open');document.getElementById('edit-'+which+'-input').focus();}
}
function applyEdit(which){var v=document.getElementById('edit-'+which+'-input').value;if(v)setTime(which,v);closeEditor(which);}
function closeEditor(which){document.getElementById('editor-'+which).classList.remove('open');}
function calcDuration(){
  if(!timeOff||!timeOn){document.getElementById('duration-display').textContent='--:--';return null;}
  var oh=+timeOff.split(':')[0],om=+timeOff.split(':')[1],nh=+timeOn.split(':')[0],nm=+timeOn.split(':')[1];
  var tot=(nh*60+nm)-(oh*60+om);if(tot<0)tot+=1440;
  var dur=String(Math.floor(tot/60)).padStart(2,'0')+':'+String(tot%60).padStart(2,'0');
  document.getElementById('duration-display').textContent=dur;return dur;
}
 
// ── TYPE ──────────────────────────────────────────────────────────
var currentType='heli';
function setType(t){
  currentType=t;
  document.getElementById('btn-heli').className='type-btn'+(t==='heli'?' active-heli':'');
  document.getElementById('btn-plane').className='type-btn'+(t==='plane'?' active-plane':'');
  document.getElementById('btn-sim').className='type-btn'+(t==='sim'?' active-sim':'');
  document.getElementById('btn-submit').className='btn-submit'+(t==='plane'?' plane-mode':t==='sim'?' sim-mode':'');
  if(timeOff)document.getElementById('stamp-off').className='clock-stamp '+stampClass();
  if(timeOn)document.getElementById('stamp-on').className='clock-stamp '+stampClass();
  renderAircraftSelect();
}
 
// ── AIRCRAFT ──────────────────────────────────────────────────────
function renderAircraftSelect(){
  var sel=document.getElementById('f-aircraft'),prev=sel.value;sel.innerHTML='';
  var filtered=Object.entries(fleet).filter(function(e){return e[1].cat===currentType;});
  if(filtered.length===0){var o=document.createElement('option');o.value='';o.textContent='— Aucun aéronef —';sel.appendChild(o);}
  else filtered.forEach(function(e){var o=document.createElement('option');o.value=e[0];o.textContent=e[0];sel.appendChild(o);});
  if(prev&&fleet[prev]&&fleet[prev].cat===currentType)sel.value=prev;
  onAircraftChange();
}
function onAircraftChange(){
  var reg=document.getElementById('f-aircraft').value,badge=document.getElementById('aircraft-type-badge');
  if(fleet[reg]){badge.textContent=fleet[reg].type;badge.className='aircraft-type-badge '+fleet[reg].cat;}
  else{badge.textContent='—';badge.className='aircraft-type-badge';}
}
 
// ── TABS ──────────────────────────────────────────────────────────
function switchTab(t){
  ['form','history','fleet'].forEach(function(id){document.getElementById('tab-'+id).style.display=id===t?'':'none';});
  document.querySelectorAll('.tab').forEach(function(el,i){el.classList.toggle('active',['form','history','fleet'][i]===t);});
}
 
// ── MODAL aéronef ─────────────────────────────────────────────────
function openModal(){document.getElementById('modal').classList.add('show');}
function closeModal(){document.getElementById('modal').classList.remove('show');document.getElementById('m-reg').value='';document.getElementById('m-type').value='';}
function addAircraft(){
  var reg=document.getElementById('m-reg').value.trim().toUpperCase(),type=document.getElementById('m-type').value.trim(),cat=document.getElementById('m-cat').value;
  if(!reg||!type){showToast('⚠ Remplis immatriculation et type',true);return;}
  fleet[reg]={type:type,cat:cat};saveFleet();closeModal();renderAircraftSelect();renderFleet();showToast('✓ '+reg+' ajouté');
}
function renderFleet(){
  var labels={heli:'🚁 Hélico',plane:'✈ Avion',sim:'🖥️ Sim'};
  var html=Object.entries(fleet).map(function(e){
    var reg=e[0],v=e[1];
    return '<div class="fleet-card"><div class="fleet-reg">'+reg+'</div><div class="fleet-type">'+v.type+'</div><span class="type-chip '+v.cat+'">'+(labels[v.cat]||v.cat)+'</span><div style="flex:1"></div><button class="del-btn" onclick="deleteAircraft(\''+reg+'\')">✕</button></div>';
  }).join('');
  document.getElementById('fleet-list').innerHTML=html||'<div style="color:var(--muted);font-family:var(--font-mono);font-size:12px;padding:12px;">Aucun aéronef.</div>';
}
function deleteAircraft(reg){if(!confirm('Supprimer '+reg+' ?'))return;delete fleet[reg];saveFleet();renderAircraftSelect();renderFleet();showToast('✓ '+reg+' supprimé');}
 
// ── DELETE MODAL ──────────────────────────────────────────────────
var pendingDeleteIdx=null;
function openDeleteModal(idx){
  pendingDeleteIdx=idx;var f=sessionFlights[idx];
  document.getElementById('delete-confirm-text').textContent=f.date+' · '+f.from+'→'+f.to+' · '+f.dur;
  document.getElementById('modal-delete').classList.add('show');
}
function closeDeleteModal(){document.getElementById('modal-delete').classList.remove('show');pendingDeleteIdx=null;}
async function confirmDelete(){
  if(pendingDeleteIdx===null)return;
  var f=sessionFlights[pendingDeleteIdx];closeDeleteModal();
  if(!f.sheetRow){showToast('⚠ Numéro de ligne inconnu',true);return;}
  setLoading(true,'SUPPRESSION...');
  try{
    var token=await getToken();
    var SHEET_MAP={heli:'Hélicoptère',plane:'Avion',sim:'Simulateur'};
    var sheetName=SHEET_MAP[f.cat]||'Hélicoptère';
    var metaResp=await fetch('https://sheets.googleapis.com/v4/spreadsheets/'+CONFIG.sheetId+'?fields=sheets.properties',{headers:{'Authorization':'Bearer '+token}});
    var metaData=await metaResp.json();
    var sheetObj=metaData.sheets.find(function(s){return s.properties.title===sheetName;});
    if(!sheetObj)throw new Error('Feuille introuvable');
    var sheetId=sheetObj.properties.sheetId;
    var delResp=await fetch('https://sheets.googleapis.com/v4/spreadsheets/'+CONFIG.sheetId+':batchUpdate',{
      method:'POST',headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
      body:JSON.stringify({requests:[{deleteDimension:{range:{sheetId:sheetId,dimension:'ROWS',startIndex:f.sheetRow-1,endIndex:f.sheetRow}}}]})
    });
    if(!delResp.ok){var e=await delResp.json();throw new Error(e.error&&e.error.message||delResp.statusText);}
    sessionFlights.forEach(function(sf){if(sf.sheetRow&&sf.sheetRow>f.sheetRow&&sf.cat===f.cat)sf.sheetRow--;});
    var dur=f.dur.split(':').map(Number);sessionMinutes-=dur[0]*60+dur[1];
    sessionFlights.splice(pendingDeleteIdx,1);
    updateStats();updateHistory();showToast('✓ Vol supprimé');
  }catch(e){showToast('✗ '+e.message,true);}
  finally{setLoading(false);}
}
 
// ── AUTH ──────────────────────────────────────────────────────────
var accessToken=null,tokenExpiry=0;
function b64u(s){return btoa(s).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');}
function b64ua(a){return btoa(String.fromCharCode.apply(null,a)).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');}
async function getToken(){
  if(accessToken&&Date.now()<tokenExpiry)return accessToken;
  var now=Math.floor(Date.now()/1000);
  var hdr=b64u(JSON.stringify({alg:'RS256',typ:'JWT'}));
  var clm=b64u(JSON.stringify({iss:CONFIG.clientEmail,scope:'https://www.googleapis.com/auth/spreadsheets',aud:'https://oauth2.googleapis.com/token',exp:now+3600,iat:now}));
  var pem=CONFIG.privateKey.replace(/-----BEGIN PRIVATE KEY-----|-----END PRIVATE KEY-----|\n/g,'');
  var der=Uint8Array.from(atob(pem),function(c){return c.charCodeAt(0);});
  var key=await crypto.subtle.importKey('pkcs8',der,{name:'RSASSA-PKCS1-v1_5',hash:'SHA-256'},false,['sign']);
  var sig=await crypto.subtle.sign('RSASSA-PKCS1-v1_5',key,new TextEncoder().encode(hdr+'.'+clm));
  var jwt=hdr+'.'+clm+'.'+b64ua(new Uint8Array(sig));
  var r=await fetch('https://oauth2.googleapis.com/token',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'grant_type=urn%3Aietf%3Aparams%3Aoauth%3Agrant-type%3Ajwt-bearer&assertion='+jwt});
  var d=await r.json();if(!d.access_token)throw new Error(JSON.stringify(d));
  accessToken=d.access_token;tokenExpiry=Date.now()+(d.expires_in-60)*1000;return accessToken;
}
 
// ── SUBMIT ────────────────────────────────────────────────────────
var sessionFlights=[],sessionMinutes=0;
var SHEET_MAP={heli:'Hélicoptère',plane:'Avion',sim:'Simulateur'};
 
async function submitFlight(){
  var date=document.getElementById('f-date').value,ac=document.getElementById('f-aircraft').value;
  var from=document.getElementById('f-from').value.trim().toUpperCase(),to=document.getElementById('f-to').value.trim().toUpperCase();
  var role=document.getElementById('f-role').value,ldgs=document.getElementById('f-ldgs').value;
  var pilots=document.getElementById('f-pilots').value.trim();
  var ifrH=document.getElementById('f-ifr-h').value.trim()||'';
  var ifrApp=document.getElementById('f-ifr-app').value||'0';
  if(!date||!timeOff||!timeOn||!from||!to){showToast('⚠ Remplis tous les champs',true);return;}
  if(!ac){showToast('⚠ Ajoute un aéronef dans l\'onglet Flotte',true);switchTab('fleet');return;}
  var dur=calcDuration();if(!dur)return;
  var ys=date.split('-'),dateF=ys[2]+'.'+ys[1]+'.'+ys[0];
  var acType=fleet[ac]?fleet[ac].type:'';
  var catLabel=currentType==='heli'?'Hélicoptère':currentType==='plane'?'Avion':'Simulateur';
  var dayH=window._dayMin!==undefined?minsToHHMM(window._dayMin):'';
  var nightH=window._nightMin!==undefined?minsToHHMM(window._nightMin):'';
  var multi_types=['AW139','BK117C1','H225','H145','AW139 SIM','H225 SIM','H145 SIM'];
  var isMulti=multi_types.indexOf(acType)>=0;
  var monoH=isMulti?'':dur,multiH=isMulti?dur:'';
  var sheetName=SHEET_MAP[currentType]||'Hélicoptère';
  var row=[dateF,role,timeOff,timeOn,dur,ldgs,ac,acType,catLabel,from,to,pilots,monoH,multiH,dayH,nightH,ifrH,ifrApp];
  setLoading(true,'→ '+sheetName+'...');
  try{
    var token=await getToken();
    // Insert at row 3
    var metaResp=await fetch('https://sheets.googleapis.com/v4/spreadsheets/'+CONFIG.sheetId+'?fields=sheets.properties',{headers:{'Authorization':'Bearer '+token}});
    var metaData=await metaResp.json();
    var sheetObj=metaData.sheets.find(function(s){return s.properties.title===sheetName;});
    if(!sheetObj)throw new Error('Feuille introuvable: '+sheetName);
    var sheetId=sheetObj.properties.sheetId;
    var insertResp=await fetch('https://sheets.googleapis.com/v4/spreadsheets/'+CONFIG.sheetId+':batchUpdate',{
      method:'POST',headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
      body:JSON.stringify({requests:[{insertDimension:{range:{sheetId:sheetId,dimension:'ROWS',startIndex:2,endIndex:3},inheritFromBefore:false}}]})
    });
    if(!insertResp.ok){var e=await insertResp.json();throw new Error(e.error&&e.error.message||insertResp.statusText);}
    var resp=await fetch('https://sheets.googleapis.com/v4/spreadsheets/'+CONFIG.sheetId+'/values/'+encodeURIComponent(sheetName)+'!A3:R3?valueInputOption=USER_ENTERED',{
      method:'PUT',headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
      body:JSON.stringify({values:[row]})
    });
    if(!resp.ok){var e2=await resp.json();throw new Error(e2.error&&e2.error.message||resp.statusText);}
    var dp=dur.split(':').map(Number);sessionMinutes+=dp[0]*60+dp[1];
    sessionFlights.unshift({date:dateF,off:timeOff,on:timeOn,dur:dur,ac:ac,acType:acType,cat:currentType,from:from,to:to,role:role,ldgs:ldgs,dayH:dayH,nightH:nightH,sheetRow:3});
    updateStats();updateHistory();
    showToast('✓ Enregistré → '+sheetName);
    resetForm();
  }catch(e){showToast('✗ '+e.message,true);}
  finally{setLoading(false);}
}
 
function resetForm(){
  timeOff='';timeOn='';window._dayMin=undefined;window._nightMin=undefined;
  ['off','on'].forEach(function(w){document.getElementById('stamp-'+w).textContent='--:--';document.getElementById('stamp-'+w).className='clock-stamp';closeEditor(w);});
  document.getElementById('f-from').value=CONFIG.homeBase||'';
  document.getElementById('f-to').value=CONFIG.homeBase||'';
  document.getElementById('f-ldgs').value='1';
  document.getElementById('f-ifr-h').value='';
  document.getElementById('f-ifr-app').value='0';
  document.getElementById('duration-display').textContent='--:--';
  document.getElementById('dn-wrap').style.display='none';
  document.getElementById('dn-no-gps').style.display='';
}
 
function updateStats(){
  document.getElementById('stat-flights').textContent=sessionFlights.length;
  document.getElementById('stat-hours').textContent=String(Math.floor(sessionMinutes/60)).padStart(2,'0')+':'+String(sessionMinutes%60).padStart(2,'0');
  document.getElementById('stat-status').textContent='SYNC ✓';
}
 
function updateHistory(){
  var list=document.getElementById('history-list');
  var labels={heli:'🚁 Hélico',plane:'✈ Avion',sim:'🖥️ Sim'};
  if(!sessionFlights.length){list.innerHTML='<div class="empty-state"><div class="icon">🛫</div><p>Aucun vol enregistré.</p></div>';return;}
  list.innerHTML=sessionFlights.map(function(f,idx){
    return '<div class="flight-card '+(f.cat==='plane'?'plane-card':f.cat==='sim'?'sim-card':'')+'">'
      +'<div class="flight-card-header"><div class="flight-date">'+f.date+' · '+f.off+'–'+f.on+' UTC</div><div class="flight-duration">'+f.dur+'</div></div>'
      +'<div class="flight-route">'+f.from+'<span class="flight-arrow">→</span>'+f.to+'</div>'
      +'<div class="flight-meta"><div>'+f.ac+' <span>'+f.acType+'</span></div><div>Rôle: <span>'+f.role+'</span></div><span class="type-chip '+f.cat+'">'+(labels[f.cat]||f.cat)+'</span></div>'
      +(((f.dayH&&f.dayH!=='00:00')||(f.nightH&&f.nightH!=='00:00'))?'<div class="dn-mini">'+(f.dayH&&f.dayH!=='00:00'?'<span class="dn-pill day">☀ Jour '+f.dayH+'</span>':'')+(f.nightH&&f.nightH!=='00:00'?'<span class="dn-pill night">🌙 Nuit '+f.nightH+'</span>':'')+'</div>':'')
      +'<button class="btn-delete" onclick="openDeleteModal('+idx+')">🗑 Supprimer ce vol</button>'
      +'</div>';
  }).join('');
}
 
function setLoading(on,msg){document.getElementById('loading').classList.toggle('show',on);if(msg)document.getElementById('loading-text').textContent=msg;document.getElementById('btn-submit').disabled=on;}
function showToast(msg,err){
  var t=document.getElementById('toast');t.textContent=msg;t.className='toast'+(err?' error':'');
  setTimeout(function(){t.classList.add('show');},10);setTimeout(function(){t.classList.remove('show');},3500);
}
</script>
